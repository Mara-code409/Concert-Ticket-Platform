@model ConcertTicketPlatform.Core.Entities.AppUser
@{
    ViewData["Title"] = "Profilul meu";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <h4 class="mb-0">👤 Profilul meu</h4>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label text-muted small">Nume complet</label>
                    <p class="fs-5 fw-semibold mb-0">@Model.FullName</p>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small">Email</label>
                    <p class="mb-0">@Model.Email</p>
                </div>
            </div>
            <div class="card-footer bg-transparent d-flex gap-2">
                <a asp-controller="Account" asp-action="MyTickets" class="btn btn-primary">
                    🎟️ Biletele mele
                </a>
                <a asp-controller="Concerts" asp-action="Index" class="btn btn-outline-secondary">
                    🔍 Caută concerte
                </a>
            </div>
        </div>
    </div>
</div>
