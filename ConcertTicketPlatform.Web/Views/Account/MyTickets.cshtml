@model List<ConcertTicketPlatform.Core.Entities.Ticket>
@using ConcertTicketPlatform.Core.Entities
@{
    ViewData["Title"] = "Biletele mele";
    var reviewedIds = ViewBag.ReviewedConcertIds as HashSet<int> ?? new HashSet<int>();
    var now = DateTime.UtcNow;
    var upcoming = Model.Where(t => t.Concert.Date >= now).OrderBy(t => t.Concert.Date).ToList();
    var past     = Model.Where(t => t.Concert.Date <  now).OrderByDescending(t => t.Concert.Date).ToList();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🎟️ Biletele mele</h2>
    <a asp-controller="Concerts" asp-action="Index" class="btn btn-outline-primary">
        + Cumpără bilete noi
    </a>
</div>

<h4 class="mb-3">
    📅 Concerte viitoare
    <span class="badge bg-primary ms-1">@upcoming.Count</span>
</h4>

@if (!upcoming.Any())
{
    <div class="alert alert-info">
        Nu ai bilete la concerte viitoare.
        <a asp-controller="Concerts" asp-action="Index" class="alert-link">Caută concerte!</a>
    </div>
}
else
{
    <div class="row mb-4">
        @foreach (var ticket in upcoming)
        {
            var daysLeft = (int)(ticket.Concert.Date - now).TotalDays;
            <div class="col-md-4 mb-3">
                <div class="card border-primary h-100">
                    <div class="card-header bg-primary text-white d-flex justify-content-between">
                        <span class="fw-semibold">🎫 Bilet valid</span>
                        <span class="badge bg-light text-primary">@daysLeft zile</span>
                    </div>
                    <div class="card-body">
                        <h6 class="card-title">@ticket.Concert.Title</h6>
                        <p class="mb-1"><strong>📍 Loc:</strong> @ticket.SeatNumber</p>
                        <p class="mb-1"><strong>📅 Data:</strong> @ticket.Concert.Date.ToString("dd MMM yyyy, HH:mm")</p>
                        <p class="mb-0 text-muted"><small>Cumpărat: @ticket.PurchasedAt.ToLocalTime().ToString("dd MMM yyyy")</small></p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a asp-controller="Concerts" asp-action="Details" asp-route-id="@ticket.ConcertId"
                           class="btn btn-sm btn-outline-primary w-100">
                            Vezi detalii concert
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<hr class="my-4" />

<h4 class="mb-3">
    ✅ Concerte la care ai participat
    <span class="badge bg-secondary ms-1">@past.Count</span>
</h4>

@if (!past.Any())
{
    <p class="text-muted">Nu ai participat la niciun concert încă.</p>
}
else
{
    @foreach (var ticket in past)
    {
        var alreadyReviewed = reviewedIds.Contains(ticket.ConcertId);
        <div class="card mb-3 @(alreadyReviewed ? "border-success" : "border-warning")">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                    <div>
                        <h6 class="mb-1 fw-bold">@ticket.Concert.Title</h6>
                        <p class="mb-1 text-muted">
                            <strong>📍</strong> Loc: @ticket.SeatNumber &nbsp;|&nbsp;
                            <strong>📅</strong> @ticket.Concert.Date.ToString("dd MMM yyyy")
                        </p>
                        <small class="text-muted">
                            Cumpărat: @ticket.PurchasedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                        </small>
                    </div>
                    <div class="text-end">
                        @if (alreadyReviewed)
                        {
                            <span class="badge bg-success fs-6">✅ Recenzie trimisă</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark fs-6">⭐ Fără recenzie</span>
                        }
                    </div>
                </div>

                @if (!alreadyReviewed)
                {
                    <div class="mt-3">
                        <button class="btn btn-sm btn-outline-warning"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#review-form-@ticket.Id"
                                aria-expanded="false">
                            ✍️ Lasă o recenzie
                        </button>

                        <div class="collapse mt-3" id="review-form-@ticket.Id">
                            <div class="card card-body bg-light border-warning">
                                <form asp-controller="Reviews" asp-action="Create" method="post">
                                    <input type="hidden" name="concertId" value="@ticket.ConcertId" />

                                    <div class="mb-2">
                                        <label class="form-label fw-semibold">Rating</label>
                                        <div class="d-flex gap-2 flex-wrap">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input" type="radio" name="rating"
                                                           id="star-@(ticket.Id)-@i" value="@i"
                                                           @(i == 5 ? "checked" : "") />
                                                    <label class="form-check-label" for="star-@(ticket.Id)-@i">
                                                        @i ⭐
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <div class="mb-2">
                                        <label class="form-label fw-semibold">Comentariu</label>
                                        <textarea name="comment" class="form-control form-control-sm" rows="3"
                                                  placeholder="Cum a fost concertul? Ce ți-a plăcut?" maxlength="500" required></textarea>
                                        <div class="form-text">Maxim 500 caractere.</div>
                                    </div>

                                    <button type="submit" class="btn btn-sm btn-warning text-dark fw-semibold">
                                        Trimite recenzia
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}
