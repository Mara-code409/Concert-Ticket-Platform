@{
    ViewData["Title"] = "Înregistrare";
}
<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">📝 Creează cont</h4>
            </div>
            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <ul class="mb-0 ps-3">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }
                <form asp-controller="Account" asp-action="Register" method="post"
                      id="register-form" novalidate>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nume complet</label>
                        <input type="text" name="fullName" class="form-control"
                               placeholder="Ion Popescu" required minlength="2" />
                        <div class="invalid-feedback">Introduceți numele complet (minim 2 caractere).</div>
                        <div class="form-text">Numele tău complet, vizibil în profil.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input type="email" name="email" class="form-control"
                               placeholder="exemplu@email.com" required />
                        <div class="invalid-feedback">Introduceți o adresă de email validă.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Parolă</label>
                        <input type="password" name="password" class="form-control"
                               placeholder="Minim 6 caractere" required minlength="6" />
                        <div class="invalid-feedback">Parola trebuie să aibă minim 6 caractere.</div>
                        <div class="form-text">Parola trebuie să conțină cel puțin o literă mare, o cifră și un caracter special.</div>
                    </div>
                    <button type="submit" class="btn btn-success w-100">Creează contul</button>
                </form>
                <hr />
                <p class="text-center mb-0">
                    Ai deja cont? <a asp-action="Login" class="text-decoration-none">Autentifică-te</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('register-form').addEventListener('submit', function (e) {
        if (!this.checkValidity()) {
            e.preventDefault();
            e.stopPropagation();
        }
        this.classList.add('was-validated');
    });
</script>
}