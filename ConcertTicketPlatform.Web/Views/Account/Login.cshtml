@{
    ViewData["Title"] = "Autentificare";
}
<div class="row justify-content-center">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">🔑 Autentificare</h4>
            </div>
            <div class="card-body">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="alert alert-danger py-2">
                        <i class="bi bi-exclamation-circle"></i> @error.ErrorMessage
                    </div>
                }
                <form asp-controller="Account" asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input type="email" name="email" class="form-control @(!ViewData.ModelState.IsValid ? "is-invalid" : "")"
                               placeholder="exemplu@email.com" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Parolă</label>
                        <input type="password" name="password" class="form-control @(!ViewData.ModelState.IsValid ? "is-invalid" : "")"
                               placeholder="••••••••" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Intră în cont</button>
                </form>
                <hr />
                <p class="text-center mb-0">
                    Nu ai cont? <a asp-action="Register" class="text-decoration-none">Înregistrează-te</a>
                </p>
            </div>
        </div>
    </div>
</div>