@{
    ViewData["Title"] = "Detalii Concert";
    var concertId  = ViewData["ConcertId"];
    var artistId   = ViewData["ArtistId"];
    var isPast     = (bool)(ViewData["IsPast"]    ?? false);
    var hasTicket  = (bool)(ViewData["HasTicket"] ?? false);
    var hasReview  = (bool)(ViewData["HasReview"] ?? false);
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div id="concert-details">
    <div class="text-center py-4">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2">Se încarcă...</p>
    </div>
</div>

<div class="mt-3 d-flex gap-2 flex-wrap">
    @if (isPast)
    {
        <span class="btn btn-secondary btn-lg disabled">🎭 Concert finalizat</span>
    }
    else if (User.Identity!.IsAuthenticated)
    {
        <form asp-controller="Concerts" asp-action="BuyTicket" asp-route-id="@concertId" method="post">
            <button type="submit" class="btn btn-success btn-lg" id="buy-btn">
                🎟️ Cumpără Bilet
            </button>
        </form>
    }
    else
    {
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-lg">
            Loghează-te pentru a cumpăra
        </a>
    }
    <a asp-controller="Concerts" asp-action="Index" class="btn btn-outline-secondary btn-lg">
        ← Înapoi
    </a>
</div>

<hr class="my-4" />

@if (isPast)
{
    <h4>
        Recenzii
        <span id="review-count" class="text-muted fs-6"></span>
    </h4>

    @if (User.Identity!.IsAuthenticated)
    {
        @if (hasTicket && !hasReview)
        {
            <div class="alert alert-info d-flex align-items-center gap-2 mb-3">
                ✍️ Ai fost la acest concert!
                <a asp-controller="Account" asp-action="MyTickets" class="alert-link">
                    Lasă o recenzie din pagina Biletele mele →
                </a>
            </div>
        }
        else if (hasReview)
        {
            <div class="alert alert-success mb-3">✅ Ai lăsat deja o recenzie pentru acest concert.</div>
        }
        else
        {
            <div class="alert alert-secondary mb-3">
                Nu ai bilet la acest concert, deci nu poți lăsa o recenzie.
            </div>
        }
    }
    else
    {
        <p class="text-muted">
            <a asp-controller="Account" asp-action="Login">Loghează-te</a>
            pentru a lăsa o recenzie.
        </p>
    }

    <div id="reviews-container">
        <div class="text-center py-3">
            <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
        </div>
    </div>
}
else
{
    <h4>
        ⭐ Ce spun fanii despre acest artist
        <span id="review-count" class="text-muted fs-6"></span>
    </h4>
    <p class="text-muted mb-3">
        Recenzii de la concertele anterioare ale acestui artist — ca să știi la ce să te aștepți!
    </p>

    <div id="reviews-container">
        <div class="text-center py-3">
            <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
        </div>
    </div>
}

@section Scripts {
<script>
    const API_BASE   = window.API_BASE;
    const concertId  = @concertId;
    const artistId   = @artistId;
    const isPast     = @(isPast ? "true" : "false");

    fetch(`${API_BASE}/api/concerts/${concertId}`)
        .then(r => r.json())
        .then(c => {
            const isSoldOut = c.availableSeats === 0;
            const dateStr   = new Date(c.date).toLocaleDateString('ro-RO', {
                weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
            });

            document.getElementById('concert-details').innerHTML = `
                <div class="card shadow-sm p-4">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <h2 class="mb-1">${c.title}</h2>
                        <span class="badge bg-primary fs-6">${c.categoryName}</span>
                    </div>
                    <p class="text-muted mb-3">${c.artistGenre}</p>
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>🎤 Artist:</strong> ${c.artistName}</p>
                            <p class="text-muted fst-italic" style="font-size:0.9rem">${c.artistBio ?? ''}</p>
                            <p><strong>📍 Venue:</strong> ${c.venueName}, ${c.venueCity}</p>
                            <p><strong>🏠 Adresă:</strong> ${c.venueAddress}</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>📅 Data:</strong> ${dateStr}</p>
                            <p><strong>💰 Preț:</strong>
                                <span class="fw-bold text-success fs-5">${c.price} RON</span>
                            </p>
                            ${!isPast ? `
                            <p>
                                <strong>🎟️ Locuri:</strong>
                                <span class="${isSoldOut ? 'text-danger fw-bold' : 'text-success'}">
                                    ${c.availableSeats} / ${c.totalSeats} disponibile
                                </span>
                            </p>
                            ${isSoldOut ? '<div class="alert alert-danger py-2">Eveniment epuizat!</div>' : ''}` : `
                            <p><span class="badge bg-secondary fs-6">🎭 Concert finalizat</span></p>`}
                        </div>
                    </div>
                </div>`;

            if (!isPast) {
                const buyBtn = document.getElementById('buy-btn');
                if (buyBtn && isSoldOut) {
                    buyBtn.disabled = true;
                    buyBtn.textContent = '❌ Epuizat';
                    buyBtn.classList.replace('btn-success', 'btn-secondary');
                }
            }
        })
        .catch(() => {
            document.getElementById('concert-details').innerHTML =
                '<p class="text-danger">Eroare la încărcarea detaliilor.</p>';
        });

    function loadReviews(url, showConcertTitle) {
        fetch(url)
            .then(r => r.json())
            .then(data => {
                const arr = Array.isArray(data) ? data : (data.$values ?? []);
                const countEl = document.getElementById('review-count');
                if (countEl) countEl.textContent = `(${arr.length})`;

                const container = document.getElementById('reviews-container');
                if (arr.length === 0) {
                    container.innerHTML = showConcertTitle
                        ? '<p class="text-muted">Niciun fan nu a lăsat recenzii pentru concertele anterioare ale acestui artist.</p>'
                        : '<p class="text-muted">Nu există recenzii încă. Fii primul — din pagina <a href="/Account/MyTickets">Biletele mele</a>!</p>';
                    return;
                }

                const stars = n => '⭐'.repeat(n) + '☆'.repeat(5 - n);
                container.innerHTML = arr.map(r => `
                    <div class="card mb-2">
                        <div class="card-body py-2">
                            ${showConcertTitle
                                ? `<div class="text-muted small mb-1">🎵 ${r.concertTitle}</div>`
                                : ''}
                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold">${r.userName ?? 'Anonim'}</span>
                                <small class="text-muted">
                                    ${new Date(r.createdAt).toLocaleDateString('ro-RO')}
                                </small>
                            </div>
                            <div>${stars(r.rating)} <span class="text-muted">(${r.rating}/5)</span></div>
                            <p class="mb-0 mt-1">${r.comment}</p>
                        </div>
                    </div>`).join('');
            })
            .catch(() => {
                document.getElementById('reviews-container').innerHTML =
                    '<p class="text-muted">Recenziile nu pot fi încărcate momentan.</p>';
            });
    }

    if (isPast) {
        loadReviews(`${API_BASE}/api/reviews?concertId=${concertId}`, false);
    } else {
        loadReviews(`${API_BASE}/api/reviews?artistId=${artistId}`, true);
    }
</script>
}
